DATABASE_URL=postgresql://user:password@host/db?sslmode=require
AUTH_SECRET=generate_with_openssl_rand_base64_32

# Gmail SMTP for transactional email notifications.
# EMAIL_PASS must be a Google "App Password" (16 chars), NOT your account password.
# Create one at https://myaccount.google.com/apppasswords (requires 2FA enabled).
# If these are unset, email sending is skipped gracefully (app keeps working).
EMAIL_USER=your_address@gmail.com
EMAIL_PASS=your_16_char_app_password
